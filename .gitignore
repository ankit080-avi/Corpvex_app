# Dependencies
node_modules/
capacitor-app/node_modules/

# Supabase CLI local link state (machine-specific)
supabase/.temp/

# Capacitor: the native Android project is regenerated by `npx cap add android`
# (build.ps1), and www/ is a build-time copy of the root web assets — don't commit
# either (avoids the "two copies drift" footgun).
capacitor-app/android/
capacitor-app/www/

# Build outputs
*.apk
*.aab
build.log

# Secrets — never commit. Use Supabase Edge Function secrets + a local filled copy.
firebase-config.local.js
.env
.env.*

# Python (ERP helper)
__pycache__/
*.pyc

# Logs & misc
*.log
.DS_Store
Thumbs.db
.idea/
*.iml
